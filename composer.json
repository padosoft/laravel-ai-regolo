{
    "name": "padosoft/laravel-ai-regolo",
    "description": "Laravel AI SDK provider extension that adds Seeweb Regolo (chat + embeddings + reranking + 30+ open models) and Ollama (local + Cloud) on top of the official laravel/ai SDK.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["laravel", "ai", "ai-sdk", "llm", "regolo", "seeweb", "ollama", "open-models", "italian-ai", "embeddings", "reranking"],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\LaravelAiRegolo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\LaravelAiRegolo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\LaravelAiRegolo\\LaravelAiRegoloServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
