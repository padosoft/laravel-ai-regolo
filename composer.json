{
    "name": "padosoft/agent-llm",
    "description": "Laravel-native agentic LLM SDK with 6 providers (OpenAI, Anthropic, Gemini, OpenRouter, Regolo, Ollama)",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["laravel", "ai", "llm", "agentic", "openai", "anthropic", "gemini", "regolo", "ollama"],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\AgentLlm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\AgentLlm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\AgentLlm\\AgentLlmServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
