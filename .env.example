# ====================================================================
# padosoft/laravel-ai-regolo — environment variables
# ====================================================================
#
# This file is the canonical reference for every environment variable
# the package reads. It is meant to be copied into the consuming
# Laravel application's `.env` file (the package itself does not load
# a `.env` from this directory — Laravel apps own that).
#
# Usage:
#
#   # in the consuming Laravel app
#   composer require padosoft/laravel-ai-regolo
#   cat vendor/padosoft/laravel-ai-regolo/.env.example >> .env
#   # then edit .env and fill in REGOLO_API_KEY (and any model overrides)
#
# Every key documented here is also documented in the README's
# "Configuration reference" section. The README is the source of truth
# for semantics; this file is the source of truth for the *list*.

# --------------------------------------------------------------------
# Runtime — required for any real call against api.regolo.ai
# --------------------------------------------------------------------

# Bearer token issued by https://regolo.ai. Without it every gateway
# call returns 401 from the upstream API.
REGOLO_API_KEY=

# --------------------------------------------------------------------
# Runtime — optional (sensible production defaults)
# --------------------------------------------------------------------

# Override only when pointing at a staging / private Regolo deployment.
# Default: https://api.regolo.ai/v1
REGOLO_BASE_URL=https://api.regolo.ai/v1

# Provider-level default timeout (seconds) for HTTP requests when the
# gateway method does NOT pass a per-call timeout argument (notably
# `RegoloGateway::rerank()`, which has no `$timeout` parameter in its
# SDK signature). The validation gate rejects empty / non-numeric /
# zero / negative values and falls back to 60s.
#
# Note: `RegoloGateway::generateImage()` has its OWN higher
# package-level fallback (120s, see `IMAGE_DEFAULT_TIMEOUT_SECONDS`)
# because Qwen-Image rendering routinely takes 8-25s. The precedence
# is: per-call `$timeout` argument → REGOLO_TIMEOUT → 120s for image
# (60s for everything else). An invalid REGOLO_TIMEOUT value (empty
# string, non-numeric, <= 0) is treated as "unset" and the
# capability-specific package default applies.
#
# Default: 60
REGOLO_TIMEOUT=60

# --------------------------------------------------------------------
# Multimodal model defaults — these env vars are NOT read directly by
# `RegoloProvider`. The package follows Laravel's standard `env() →
# config() → provider` flow, so the consuming app wires them into its
# own `config/ai.php` (under `providers.regolo.models.*.default`) the
# same way the existing `REGOLO_API_KEY` and `REGOLO_BASE_URL` are
# wired:
#
#   'image' => [
#       'default' => env('REGOLO_IMAGE_MODEL', 'Qwen-Image'),
#   ],
#   'transcription' => [
#       'default' => env('REGOLO_TRANSCRIPTION_MODEL', 'faster-whisper-large-v3'),
#   ],
#   'audio' => [
#       'default' => env('REGOLO_AUDIO_MODEL'),
#   ],
#
# When `config/ai.php` does not pin a value, `RegoloProvider` falls
# back to the same hard-coded defaults documented below.
# --------------------------------------------------------------------

# Default model for `Image::of(...)->generate('regolo', ...)` calls.
# Default: Qwen-Image (catalogue-listed at GET /v1/models)
REGOLO_IMAGE_MODEL=Qwen-Image

# Default model for `Transcription::of($audio)->using('regolo', ...)`
# calls. Default: faster-whisper-large-v3 (catalogue-listed; the docs
# recommend keeping audio chunks < 2 minutes for best latency).
REGOLO_TRANSCRIPTION_MODEL=faster-whisper-large-v3

# Default model for `Audio::for($text)->generate('regolo', ...)` (TTS)
# calls. IMPORTANT: Regolo's TTS catalogue is not fully public yet.
# When this var is unset, `RegoloProvider::defaultAudioModel()` returns
# an empty string — which surfaces as a clear "model required"
# upstream error rather than a hard-coded guess that may not exist.
# Set it explicitly once Seeweb publishes the TTS model catalogue.
# REGOLO_AUDIO_MODEL=

# --------------------------------------------------------------------
# Live test suite — only read by `tests/Live/*` when you explicitly
# invoke `vendor/bin/phpunit --testsuite Live` against the real API.
# CI never reads these (the suite self-skips on missing API key).
# Leave the model overrides unset to use the SDK defaults below.
# --------------------------------------------------------------------

# Default: Llama-3.1-8B-Instruct
REGOLO_LIVE_TEXT_MODEL=Llama-3.1-8B-Instruct

# Default: Qwen3-Embedding-8B
REGOLO_LIVE_EMBEDDINGS_MODEL=Qwen3-Embedding-8B

# Default: jina-reranker-v2
REGOLO_LIVE_RERANKING_MODEL=jina-reranker-v2

# Default: Qwen-Image
REGOLO_LIVE_IMAGE_MODEL=Qwen-Image

# Default: faster-whisper-large-v3
REGOLO_LIVE_TRANSCRIPTION_MODEL=faster-whisper-large-v3

# Live TTS (text-to-speech) — REQUIRED to opt into the audio test.
# Regolo's TTS catalogue is not on `GET /v1/models` yet; the model
# id has to come from Seeweb directly through their commercial /
# early-access channel. Without this, RegoloAudioLiveTest
# self-skips (intentional safety against accidentally running
# against a non-existent model id).
# REGOLO_LIVE_AUDIO_MODEL=

# Voice id forwarded verbatim to /v1/audio/speech. Default:
# `alloy` because Regolo's Audio gateway accepts the OpenAI-canonical
# voice names. Override if your Seeweb-provided model ships a
# different voice catalogue.
REGOLO_LIVE_AUDIO_VOICE=alloy

# Live transcription — path to a real speech recording.
# Whisper-style models produce empty/nonsense output on synthetic
# audio (sine waves, silence), so a real recording is required.
# Use any short MP3 / WAV / OGG / FLAC / M4A clip you have on disk.
# Without this, RegoloTranscriptionLiveTest self-skips.
# REGOLO_LIVE_TRANSCRIPTION_AUDIO_PATH=/path/to/sample.mp3

# Optional ISO 639-1 language hint for transcription. Omit to let
# Whisper auto-detect. Common values: it, en, fr, de, es.
# REGOLO_LIVE_TRANSCRIPTION_LANGUAGE=it

# Live-suite-only HTTP timeout (seconds). Mirrors REGOLO_TIMEOUT but is
# scoped to the live tests; same validation gate (numeric + >= 1 + safe
# 60s fallback). Default: 60
REGOLO_LIVE_TIMEOUT=60
